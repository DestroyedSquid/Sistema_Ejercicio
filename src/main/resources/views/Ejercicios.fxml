<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="600.0" prefWidth="800.0" stylesheets="@../styles/estilos.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.uacm.sistema_ejercicio.controlador.ControladorEjercicio">
    <children>

        <VBox alignment="CENTER" prefWidth="400.0" spacing="20.0" styleClass="panel-animacion" HBox.hgrow="ALWAYS">
            <children>
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label fx:id="lblNombreEjercicio" styleClass="texto-titulo" text="Nombre del Ejercicio" />
                        <Button fx:id="btnInfo" mnemonicParsing="false" styleClass="boton-info" text="?" />
                    </children>
                </HBox>
                <ImageView fx:id="imgAnimacion" fitHeight="300.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="true" />
            </children>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </VBox>

        <VBox alignment="CENTER" prefWidth="400.0" spacing="30.0" styleClass="panel-controles" HBox.hgrow="ALWAYS">
            <children>
                <Label styleClass="texto-subtitulo" text="TU OBJETIVO" />
                <Label fx:id="lblMeta" styleClass="texto-destacado" text="Meta: -- Repeticiones" />

                <VBox alignment="CENTER" spacing="15.0" styleClass="caja-input">
                    <children>
                        <Label styleClass="texto-normal" text="¿Cuántas hiciste realmente?" />
                        <TextField fx:id="txtRepeticionesReales" alignment="CENTER" maxWidth="150.0" promptText="Ej. 12" styleClass="input-reps" />
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>

                <Button fx:id="btnSiguiente" mnemonicParsing="false" onAction="#registrarYContinuar" prefHeight="60.0" prefWidth="250.0" styleClass="boton-siguiente" text="SIGUIENTE EJERCICIO ➔" />
            </children>
        </VBox>

    </children>
</HBox>