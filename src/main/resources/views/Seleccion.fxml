<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.uacm.sistema_ejercicio.controlador.SeleccionControlador">
    <top>
        <VBox alignment="CENTER" prefHeight="100.0" style="-fx-background-color: #2c3e50;">
            <Label text="FitSystem - Configura tu Rutina" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="24.0" />
                </font>
            </Label>
        </VBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="30.0" BorderPane.alignment="CENTER">
            <children>
                <VBox alignment="CENTER" spacing="10.0">
                    <Label text="1. Selecciona el Grupo Muscular">
                        <font>
                            <Font size="16.0" />
                        </font>
                    </Label>
                    <ComboBox fx:id="comboMusculo" prefWidth="250.0" promptText="Ej. Brazo" />
                </VBox>
                <VBox alignment="CENTER" spacing="10.0">
                    <Label text="2. Selecciona tu Nivel">
                        <font>
                            <Font size="16.0" />
                        </font>
                    </Label>
                    <ComboBox fx:id="comboNivel" prefWidth="250.0" promptText="Ej. Intermedio" />
                </VBox>
            </children>
        </VBox>
    </center>
    <bottom>
        <VBox alignment="CENTER" prefHeight="120.0" BorderPane.alignment="CENTER">
            <Button fx:id="btnIniciar" mnemonicParsing="false" onAction="#iniciarEntrenamiento" prefHeight="50.0" prefWidth="300.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px;" text="¡INICIAR ENTRENAMIENTO!" />
        </VBox>
    </bottom>
</BorderPane>